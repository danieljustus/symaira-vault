# Symaira Vault configuration example.
# Copy this file to $XDG_CONFIG_HOME/symaira-vault/config.yaml (defaults to
# ~/.config/symaira-vault/config.yaml) for global settings, or to a vault
# directory as config.yaml for vault-specific settings.
# Legacy installs that still have a ~/.symvault directory keep reading and
# writing config.yaml there until migrated; see internal/config/paths.go.

# Default vault directory used when SYMVAULT_VAULT and --vault are not set.
# New installs default to the XDG data directory (see
# internal/config.DefaultDataDir), typically ~/.local/share/symaira-vault.
# Legacy installs keep using ~/.symvault until migrated.
vaultDir: ~/.local/share/symaira-vault

# Default MCP agent profile used when --agent is not set.
defaultAgent: default

# OS keyring cache TTL for unlocked vault passphrases.
sessionTimeout: 15m

# Unlock method for this vault. Use "touchid" on macOS to allow Touch ID
# unlock after the passphrase has been stored in the biometric Keychain item.
# Change with: symvault auth set passphrase|touchid
authMethod: passphrase

# Agent profiles for MCP access.
agents:
  default:
    # Prefix patterns the agent can access. Use ["*"] for all entries.
    allowedPaths: ["*"]
    # Whether the agent can create, update, or delete entries.
    canWrite: false
    # Whether the agent may change Symaira Vault auth/config settings through MCP.
    canManageConfig: false
    # none allows configured operations, deny rejects writes, prompt degrades to
    # deny in MCP contexts where interactive approval is unavailable.
    approvalMode: none
    # Timeout for interactive approval prompts (approvalMode: prompt).
    # Overrides the global mcp.approval_timeout for this agent.
    # approvalTimeout: 30s
  # Read-only agents: codex and opencode default to canWrite=false for safety.
  # These agents are designed for read-only vault access.
  codex:
    allowedPaths: ["work/", "personal/"]
    canWrite: false
    approvalMode: none
    # approvalTimeout: 60s

  # Write-capable agents: claude-code, hermes, and openclaw have canWrite=true.
  # These agents are allowed to create, update, and delete vault entries.
  hermes:
    allowedPaths: ["*"]
    canWrite: true
    canManageConfig: false
    approvalMode: none

# Vault-specific settings. These can also live inside <vault>/config.yaml.
vault:
  # Vault directory path.
  # New installs default to the XDG data directory (see
  # internal/config.DefaultDataDir), typically ~/.local/share/symaira-vault.
  # Legacy installs keep using ~/.symvault until migrated.
  path: ~/.local/share/symaira-vault
  # Age recipients used for newly written entries.
  default_recipients: []
  #  - age1...
  # Ask for confirmation before removing recipients.
  confirm_remove: true
  # Optional per-vault override for authMethod.
  # authMethod: touchid
  # Number of concurrent workers for search/listing decryption. Set to 0 (default)
  # for auto-scaling based on CPU count (min(runtime.NumCPU(), 8)). Increase for
  # large vaults with many entries to improve search throughput.
  # search_workers: 4
  # Cache TTL for entry listing results. Set to 0 to disable caching.
  # Default is 300s (5 minutes). Shorter values reduce staleness at the cost
  # of more frequent directory walks.
  # listing_cache_ttl: 300s

# Git integration for automatic commits and optional pushes.
git:
  # Automatically push after Symaira Vault commits a vault change.
  auto_push: true
  # Commit message used for automatic commits.
  commit_template: "Update from Symaira Vault"

# MCP server configuration.
mcp:
  # HTTP server bind address and port.
  bind: 127.0.0.1
  port: 8080
  # Use stdio transport instead of HTTP.
  stdio: false
  # HTTP bearer token file path. "auto" stores mcp-token in the vault.
  httpTokenFile: auto
  # OpenTelemetry OTLP endpoint for traces. Uses HTTP/protobuf.
  # When empty, falls back to the SYMVAULT_OTLP_ENDPOINT environment variable.
  # Example: "localhost:4318" for a local OTel collector.
  # otlp_endpoint: localhost:4318
  # Require bearer token for /metrics on non-loopback binds. Default is true.
  # Set to false to allow anonymous metrics access when bound to non-local addresses.
  # metrics_auth_required: true
  # HTTP server timeouts. Increase for slow networks or large payloads.
  # read_header_timeout: 5s
  # read_timeout: 10s
  # write_timeout: 10s
  # shutdown_timeout: 5s
  # Default timeout for interactive approval prompts (approvalMode: prompt).
  # Can be overridden per agent profile via approvalTimeout.
  # approval_timeout: 30s
  # Rate limit for MCP HTTP requests (requests per minute). Set to 0 to disable.
  # rate_limit: 60

# Environment variable allowlist for subprocess execution.
# Only these vars are passed to child processes (git, gpg, editors, etc.),
# preventing leakage of sensitive env vars (API keys, tokens, etc.).
# The default allowlist includes PATH, HOME, TMPDIR, TEMP, TMP, USER,
# LOGNAME, LANG, LC_ALL, SHELL, TERM, COLORTERM, DISPLAY, XAUTHORITY,
# GIT_ASKPASS, GIT_SSH, GIT_SSH_COMMAND, SSH_AUTH_SOCK,
# SSH_AGENT_LAUNCHER, and GNUPGHOME.
# Use this list to add additional vars your workflow requires.
# envAllowlist:
#   - MY_CUSTOM_VAR
#   - ANOTHER_VAR

# Update check configuration.
update:
  # Cache TTL for update check results. Set to 0 to disable caching.
  # cache_ttl: 24h

# Clipboard behavior.
clipboard:
  # Seconds before copied secrets are cleared. Set 0 to disable auto-clear.
  auto_clear_duration: 30
  # Copy field values to the clipboard by default on a TTY.
  # Set false to print to stdout unless --print is already supplied.
  copyByDefault: true

# Custom PII/secret scan patterns for the output sanitizer.
# These are merged with built-in defaults and compiled at runtime.
# Each pattern is a named regex with a description and severity level.
# The sanitize_output MCP tool uses these to detect and mask sensitive
# data before sending output to AI agents.
# scan_patterns:
#   - name: my_custom_token
#     pattern: "\\b(mytok_[a-zA-Z0-9]{32})\\b"
#     description: "My Custom API Token"
#     severity: "high"

# Audit log configuration.
audit:
  # Maximum size of a single audit log file in MB before rotation.
  maxSizeMb: 100
  # Number of rotated backup files to retain.
  maxBackups: 5
  # Maximum age of rotated backup files in days before deletion.
  maxAgeDays: 30
