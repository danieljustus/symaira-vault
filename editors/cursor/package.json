{
  "name": "symvault-cursor",
  "displayName": "Symaira Vault for Cursor",
  "description": "Symaira Vault secret manager integration for Cursor IDE",
  "version": "1.0.0",
  "publisher": "danieljustus",
  "engines": {
    "vscode": "^>=1.85.0",
    "cursor": "^>=0.40.0"
  },
  "categories": ["Other"],
  "keywords": ["symvault", "password", "secret", "mcp"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "symvault.cursor.refreshContext",
        "title": "Refresh Symaira Vault Context",
        "category": "Symaira Vault"
      }
    ],
    "configuration": {
      "title": "Symaira Vault Cursor",
      "properties": {
        "symvault.cursor.injectCursorrules": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject Symaira Vault context into .cursorrules"
        },
        "symvault.cursor.contextFile": {
          "type": "string",
          "default": ".cursorrules",
          "description": "Path to Cursor context file (relative to workspace root)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@symaira/mcp-client": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0"
  }
}
