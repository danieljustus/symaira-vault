.nh
.TH "SYMAIRA" "1" "Apr 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-recipients-list - List all recipients


.SH SYNOPSIS
\fBsymaira recipients list [flags]\fP


.SH DESCRIPTION
List all recipients from the recipients.txt file.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB-j\fP, \fB--json\fP[=false]
	Output as JSON


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBsymaira-recipients(1)\fP
