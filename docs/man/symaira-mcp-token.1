.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-mcp-token - Manage MCP scoped tokens


.SH SYNOPSIS
\fBsymaira mcp token [flags]\fP


.SH DESCRIPTION
Create, list, and revoke per-tool scoped tokens for MCP HTTP authentication.

.PP
Scoped tokens allow fine-grained access control for MCP clients. Each token can
be restricted to specific tools and has an optional expiration time.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for token


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH EXAMPLE
.EX
  # Create a read-only token expiring in 24h
   openpass mcp token create --name "ci-readonly" --tools list,get --ttl 24h

   # List all tokens
   openpass mcp token list

   # Revoke by ID
   openpass mcp token revoke <token-id>
.EE


.SH SEE ALSO
\fBsymaira-mcp(1)\fP, \fBsymaira-mcp-token-create(1)\fP, \fBsymaira-mcp-token-list(1)\fP, \fBsymaira-mcp-token-revoke(1)\fP
