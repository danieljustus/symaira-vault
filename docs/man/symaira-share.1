.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-share - Manage secret sharing between agents


.SH SYNOPSIS
\fBsymaira share [flags]\fP


.SH DESCRIPTION
List and revoke secret share grants between MCP agents.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for share


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH EXAMPLE
.EX
  # List all pending share requests
  openpass share list --status pending

  # Revoke a grant by ID
  openpass share revoke <grant-id>

  # JSON output for tooling
  openpass share list --output json
.EE


.SH SEE ALSO
\fBopenpass(1)\fP, \fBsymaira-share-list(1)\fP, \fBsymaira-share-revoke(1)\fP
