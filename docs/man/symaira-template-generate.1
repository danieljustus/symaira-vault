.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-template-generate - Generate a configuration file from a template


.SH SYNOPSIS
\fBsymaira template generate [flags]\fP


.SH DESCRIPTION
Generate a configuration file from a template


.SH OPTIONS
\fB--dry-run\fP[=false]
	Show template with masked values

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for generate

.PP
\fB--name\fP="app"
	Name of the resource being generated

.PP
\fB--output\fP=""
	Output file path (optional)

.PP
\fB--type\fP=""
	Template type (env, docker-compose, k8s-secret, github-actions, terraform)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH EXAMPLE
.EX
  # Generate .env file from vault secrets
  openpass template generate --type env --name myapp

  # Generate Kubernetes secret manifest
  openpass template generate --type k8s-secret --name myapp --output k8s/secret.yaml

  # Dry-run to preview without real values
  openpass template generate --type env --name myapp --dry-run
.EE


.SH SEE ALSO
\fBsymaira-template(1)\fP
