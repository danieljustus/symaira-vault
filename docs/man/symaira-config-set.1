.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-config-set - Set a configuration value


.SH SYNOPSIS
\fBsymaira config set   [flags]\fP


.SH DESCRIPTION
Set the value of a configuration key using dotted path notation.
The value is automatically parsed as YAML to infer types: true/false for booleans,
numbers for integers, and quoted strings for text.

.PP
Examples:
  openpass config set vaultDir ~/my-vault
  openpass config set agents.claude-code.canWrite true
  openpass config set mcp.port 9090
  openpass config set clipboard.auto_clear_duration 60


.SH OPTIONS
\fB--file\fP=""
	path to config file (default: ~/.openpass/config.yaml)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for set


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBsymaira-config(1)\fP
