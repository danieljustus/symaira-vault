.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-agent-token - Manage tokens for an agent


.SH SYNOPSIS
\fBsymaira agent token  [flags]\fP


.SH DESCRIPTION
Create, list, revoke, and rotate scoped tokens for a specific agent.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for token


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH EXAMPLE
.EX
  # Create a scoped token for an agent
  openpass agent token my-agent new

  # List tokens for an agent
  openpass agent token my-agent list

  # Revoke a token by ID
  openpass agent token my-agent revoke <token-id>

  # Rotate an agent's token (revoke + create new)
  openpass agent token my-agent rotate
.EE


.SH SEE ALSO
\fBsymaira-agent(1)\fP, \fBsymaira-agent-token-list(1)\fP, \fBsymaira-agent-token-new(1)\fP, \fBsymaira-agent-token-revoke(1)\fP, \fBsymaira-agent-token-rotate(1)\fP
