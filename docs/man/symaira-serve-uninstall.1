.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-serve-uninstall - Remove the MCP server background service


.SH SYNOPSIS
\fBsymaira serve uninstall [flags]\fP


.SH DESCRIPTION
Stop and remove the OpenPass MCP server background service.

.PP
On macOS, this unloads the LaunchAgent and removes the plist file.

.PP
On Linux, this stops and disables the systemd user service and removes
the service file.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for uninstall


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBsymaira-serve(1)\fP
