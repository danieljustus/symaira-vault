.TH "SYMAIRA" "1" "Apr 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-serve - Start MCP server for agent access


.SH SYNOPSIS
\fBsymaira serve [flags]\fP


.SH DESCRIPTION
Start an MCP server that exposes vault operations to AI agents.

.PP
Each agent must be configured in ~/.openpass/config.yaml with specific
permissions and scope restrictions.

.PP
The server can run in HTTP mode or stdio mode.


.SH OPTIONS
\fB--agent\fP=""
	Agent name (required for --stdio; HTTP mode resolves agents per-request via X-OpenPass-Agent header)

.PP
\fB--bind\fP="127.0.0.1"
	Bind address for HTTP server

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for serve

.PP
\fB--port\fP=8080
	Server port

.PP
\fB--stdio\fP[=false]
	Enable stdio transport (for MCP)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP
