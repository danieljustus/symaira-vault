.TH "SYMAIRA" "1" "Apr 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-ui - Launch the OpenPass terminal UI


.SH SYNOPSIS
\fBsymaira ui [flags]\fP


.SH DESCRIPTION
Launches the interactive terminal UI for browsing and managing the vault.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for ui


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP
