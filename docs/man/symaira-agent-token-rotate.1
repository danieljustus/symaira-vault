.nh
.TH "SYMAIRA" "1" "May 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-agent-token-rotate - Rotate the agent's token


.SH SYNOPSIS
\fBsymaira agent token rotate [flags]\fP


.SH DESCRIPTION
Revoke the current token for this agent and create a new one.
The new raw token is printed exactly once.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for rotate

.PP
\fB--label\fP=""
	Human-readable label

.PP
\fB--tools\fP=[\fI]
	Comma-separated allowed tools, or '\fP\&' for all

.PP
\fB--ttl\fP=""
	Token TTL (e.g. 24h, 7d); defaults to mcp.scoped_token_ttl from config


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--color\fP="auto"
	When to emit ANSI color: auto, always, never

.PP
\fB--no-pipe-warning\fP[=false]
	suppress 'reading from non-TTY' warning when piping secrets

.PP
\fB--output\fP="text"
	Output format (text, json, yaml)

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--theme\fP=""
	Color preset: default, highcontrast, colorblind (or OPENPASS_THEME)

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBsymaira-agent-token(1)\fP
