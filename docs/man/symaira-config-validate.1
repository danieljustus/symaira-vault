.TH "SYMAIRA" "1" "Apr 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-config-validate - Validate the configuration file


.SH SYNOPSIS
\fBsymaira config validate [path] [flags]\fP


.SH DESCRIPTION
Validate the OpenPass configuration file for schema errors.

.PP
If no path is given, validates the default config at ~/.openpass/config.yaml.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for validate

.PP
\fB--json\fP[=false]
	output validation result as JSON


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBsymaira-config(1)\fP
