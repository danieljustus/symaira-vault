.TH "SYMAIRA" "1" "Apr 2026" "Symaira Vault" "OpenPass Manual"

.SH NAME
symaira-mcp-token-rotate - Rotate the MCP HTTP bearer token


.SH SYNOPSIS
\fBsymaira mcp-token-rotate [flags]\fP


.SH DESCRIPTION
Generate a new MCP HTTP bearer token, invalidating the previous one.

.PP
This command generates a new 32-byte random token and writes it to the
mcp-token file in your vault directory. Any MCP clients using the old token
will need to be updated with the new token.

.PP
After rotating, run 'openpass mcp-config [agent] --http' to see the new token.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for mcp-token-rotate


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP
